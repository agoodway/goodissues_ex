# Project automation recipes

# Start development server
up:
    bun run dev

# Deploy to production
deploy:
    docker build -t fruitfly-site .

# Run Astro checks
test:
    bun run check

# Run type and content checks
check:
    bun run check

# Build the project
build:
    bun run build

# Preview production build locally
preview:
    bun run preview

# Clean build artifacts
clean:
    rm -rf node_modules dist .astro
