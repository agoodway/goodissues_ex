# Project automation recipes

# Start development server
up:
    PORT=8383 mix phx.server

# Deploy to production
deploy:
    # TODO: Configure deployment (fly deploy, docker, etc.)
    @echo "Deployment not configured. Add fly.toml or configure deploy recipe."

# Run tests
test:
    mix test

# Run quality checks (format, credo, doctor, dialyzer, tests)
check:
    mix check

# Compile the project
build:
    mix compile

# Clean build artifacts
clean:
    mix clean
    rm -rf _build deps

# Setup project (deps, database, assets)
setup:
    mix setup

# Reset database
db-reset:
    mix ecto.reset

# Run database migrations
db-migrate:
    mix ecto.migrate

# Generate a new migration
db-gen name:
    mix ecto.gen.migration {{name}}

# Start interactive console
console:
    iex -S mix

# Start console with Phoenix server
console-server:
    PORT=8383 iex -S mix phx.server

# Format code
fmt:
    mix format

# Install dependencies
deps:
    mix deps.get
